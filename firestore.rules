rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    function signedIn()  { return request.auth != null; }
    function role()      { return request.auth.token.role; }
    function isAdmin()   { return role() == 'admin'; }
    function isTecnico() { return role() == 'tecnico'; }
    function locked(d)   { return d.status == 'completo' || d.status == 'firmado'; }

    // #19 — El admin puede reabrir un doc bloqueado, pero SOLO como transición
    // exacta a en_progreso tocando nada más que estos campos (no reedita
    // contenido bloqueado en el mismo write).
    function isReopen(before, after) {
      return locked(before)
          && after.status == 'en_progreso'
          && after.diff(before).affectedKeys()
               .hasOnly(['status','updatedAt','updatedBy','reopenedAt','reopenedBy']);
    }

    // #7 — Valida que todos los valores del mapa docStatus estén en el enum.
    // Los 6 docTypes siempre existen (initEmptyDocs los inicializa al crear el proyecto).
    function validDocStatusMap(ds) {
      return ds.VT in ['vacio','en_progreso','completo','firmado']
          && ds.EP in ['vacio','en_progreso','completo','firmado']
          && ds.OT in ['vacio','en_progreso','completo','firmado']
          && ds.RF in ['vacio','en_progreso','completo','firmado']
          && ds.AC in ['vacio','en_progreso','completo','firmado']
          && ds.FM in ['vacio','en_progreso','completo','firmado'];
    }

    // #7 — El técnico solo puede avanzar el estado del proyecto, nunca
    // retroceder ni saltear pasos (borrador → en_curso → entregado).
    function validProjectStatusTransition(current, next) {
      return (current == 'borrador'  && next in ['borrador', 'en_curso'])
          || (current == 'en_curso'  && next in ['en_curso', 'entregado'])
          || (current == 'entregado' && next == 'entregado');
    }

    // #7 — No permite marcar el proyecto como 'entregado' si el AC no está
    // firmado. Costo: 1 lectura extra por escritura; aceptable para uso interno.
    function acEstaFirmado(code) {
      return get(/databases/$(db)/documents/projects/$(code)/documents/AC)
               .data.status == 'firmado';
    }

    // #21 — Documento anterior en el protocolo VT→EP→OT→RF→AC→FM.
    function prevDocType(dt) {
      return dt == 'EP' ? 'VT'
           : dt == 'OT' ? 'EP'
           : dt == 'RF' ? 'OT'
           : dt == 'AC' ? 'RF'
           : dt == 'FM' ? 'AC'
           : '';   // VT no tiene anterior.
    }
    function docCerrado(code, dt) {
      return get(/databases/$(db)/documents/projects/$(code)/documents/$(dt))
               .data.status in ['completo','firmado'];
    }
    function rfApto(code) {
      return get(/databases/$(db)/documents/projects/$(code)/documents/RF)
               .data.aptoEntrega == true;
    }
    // Un proyecto archivado es de solo lectura: ninguna escritura en sus
    // documentos (para editar hay que desarchivarlo primero). Cuesta 1 lectura
    // por escritura de documento; aceptable para uso interno.
    function projectArchived(code) {
      return get(/databases/$(db)/documents/projects/$(code))
               .data.status == 'archivado';
    }

    // #21 — Un documento solo se cierra (completo/firmado) si el anterior del
    // protocolo ya está cerrado; el acta (AC) además exige RF apto para entrega.
    // Solo cuesta lecturas extra al cerrar, no en cada autosave.
    function secuenciaOk(code, docType, newStatus) {
      return !(newStatus in ['completo','firmado'])
          || ((docType == 'VT' || docCerrado(code, prevDocType(docType)))
              && (docType != 'AC' || rfApto(code)));
    }

    match /clients/{clientId} {
      allow read:   if signedIn();
      allow create: if false;  // solo Admin SDK crea clientes
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /users/{uid} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    match /counters/{year} {
      // Solo escribe el Admin SDK (creación/duplicación de proyectos).
      allow read:  if signedIn();
      allow write: if false;
    }

    match /config/{document} {
      allow read:  if signedIn();   // los forms lo leen para sembrar
      allow write: if isAdmin();    // solo admin edita el protocolo
    }

    match /signRequests/{token} {
      // Solicitudes de firma remota del acta: solo el Admin SDK (/api/sign)
      // las lee y escribe. Ningún cliente —ni admin— accede directo: el token
      // es la credencial del link público y no debe poder enumerarse.
      allow read, write: if false;
    }

    match /projects/{code} {
      allow read:   if signedIn();
      allow create: if isAdmin();
      allow update: if (isAdmin()
                        // #11 — Congela createdAt/createdBy: ningún update los puede mutar.
                        && request.resource.data.createdAt == resource.data.createdAt
                        && request.resource.data.createdBy == resource.data.createdBy)
                    || (isTecnico()
                          // Solo puede tocar estos cuatro campos.
                          && request.resource.data.diff(resource.data)
                              .affectedKeys().hasOnly(['docStatus','status','updatedAt','updatedBy'])
                          // #11 — updatedBy debe ser el uid del técnico que escribe.
                          && request.resource.data.updatedBy == request.auth.uid
                          // status del proyecto debe ser un valor del enum.
                          && request.resource.data.status in ['borrador','en_curso','entregado']
                          // Sin saltos ni retrocesos en el flujo.
                          && validProjectStatusTransition(
                               resource.data.status,
                               request.resource.data.status)
                          // Cada slot de docStatus debe tener un valor del enum.
                          && validDocStatusMap(request.resource.data.docStatus)
                          // No puede marcar entregado si el AC no está firmado.
                          && (request.resource.data.status != 'entregado'
                               || acEstaFirmado(code)));
      allow delete: if isAdmin();

      match /documents/{docType} {
        allow read: if signedIn();
        // Admin: acceso a los 6 documentos, pero no puede mutar un doc ya bloqueado.
        // Técnico: solo VT, EP, OT, RF.
        // (#5 reglas) AC y FM son exclusivos del admin, coherente con el
        //             guard de UI en ACForm (Batch 3).
        allow write: if !projectArchived(code)
                     && ((isAdmin()
                          && (resource == null
                              || !locked(resource.data)
                              || isReopen(resource.data, request.resource.data))
                          // #21 — no puede cerrar fuera de secuencia (delete: request.resource == null).
                          && (request.resource == null
                              || secuenciaOk(code, docType, request.resource.data.status)))
                     || (isTecnico()
                          && docType in ['VT','EP','OT','RF']
                          && (resource == null || !locked(resource.data))
                          // #7 — status del documento también debe ser del enum.
                          && request.resource.data.status
                               in ['vacio','en_progreso','completo','firmado']
                          // #21 — no puede cerrar fuera de secuencia.
                          && secuenciaOk(code, docType, request.resource.data.status)));
      }

      match /revisions/{rev} {
        allow read:           if signedIn();
        // #10 — by debe ser el uid del autor; at debe ser el timestamp del servidor.
        allow create:         if signedIn()
                                 && request.resource.data.by == request.auth.uid
                                 && request.resource.data.at == request.time;
        allow update, delete: if false;
      }
    }
  }
}
